# Sherlock — Environment Configuration
# Copy to .env and fill in your values.

# Default New Relic account ID (optional — can also be set via connect_account tool)
NEW_RELIC_ACCOUNT_ID=

# Default New Relic User API key (optional — prefer keyring storage via connect_account)
NEW_RELIC_API_KEY=

# Region: US or EU (default: US)
NEW_RELIC_REGION=US

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Cache TTL in seconds (default: 1800 = 30 minutes)
CACHE_TTL_SECONDS=1800
